# Local dev
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost/autoshare

# Supabase (production) — get from Supabase dashboard → Settings → Database → Connection string → URI
# Change "postgresql://" to "postgresql+asyncpg://" and use port 5432 (direct, not pooler)
DATABASE_URL=postgresql+asyncpg://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Read-only PAT from nepnpc account with read:packages scope — injected into each user's repo
GHCR_PAT=

FRONTEND_URL=https://autoshare.app
BACKEND_URL=https://api.autoshare.app
DOCKER_IMAGE=ghcr.io/nepnpc/autoshare-bot:latest
